            "description": "When the source system says this class record last changed.",
            "format": "date-time"
          }
        }
      },
      "Enrollment": {
        "type": "object",
        "description": "A record that says a person participates in a class with a specific role.",
        "required": [
          "id",
          "sourcedId",
          "classId",
          "personId",
          "schoolId",
          "role",
          "status",
          "dateLastModified"
