      "Class": {
        "type": "object",
        "description": "A scheduled class or section where learners and teachers meet around a course.",
        "required": [
          "id",
          "sourcedId",
          "title",
          "classType",
          "courseId",
          "schoolId",
          "status",
          "dateLastModified"
