          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "sql"
                ],
                "properties": {
                  "sql": {
                    "type": "string",
                    "examples": [
                      "select display_name, primary_role from people order by display_name"
                    ]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Rows returned by the query.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SqlQueryResult"
                }
              }
            }
          },
          "400": {
            "description": "The query was not accepted."
          }
        }
      }
    },
