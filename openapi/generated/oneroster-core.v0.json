  "components": {
    "schemas": {
      "Organization": {
        "type": "object",
        "description": "A district, school, department, program, or other education organization.",
        "required": [
          "id",
          "sourcedId",
          "name",
          "type",
          "status",
          "dateLastModified"
        ],
        "properties": {
          "id": {
            "type": "string",
            "description": "The platform's stable ID for this organization.",
            "x-decisionId": "DEC-007-identifier-crosswalk"
          },
          "sourcedId": {
            "type": "string",
            "description": "The OneRoster source ID used by the sending system.",
            "x-decisionId": "DEC-007-identifier-crosswalk"
          },
          "name": {
            "type": "string",
            "description": "The organization name people recognize.",
            "x-decisionId": "DEC-002-learning-context"
          },
          "type": {
            "type": "string",
            "description": "The kind of organization this record represents.",
            "x-decisionId": "DEC-002-learning-context",
            "enum": [
              "district",
              "school",
              "department",
              "program"
            ]
          },
          "parentOrganizationId": {
            "type": "string",
            "description": "The organization that contains this one.",
            "x-decisionId": "DEC-007-identifier-crosswalk"
          },
          "status": {
            "type": "string",
            "description": "Whether the record is active, inactive, or marked for deletion.",
            "x-decisionId": "DEC-002-learning-context",
            "enum": [
              "active",
              "inactive",
              "tobedeleted"
            ]
          },
          "dateLastModified": {
            "type": "string",
            "description": "When the source system says this organization record last changed.",
            "x-decisionId": "DEC-008-time-session",
            "format": "date-time"
          }
        }
      },
      "Person": {
        "type": "object",
        "description": "A learner, teacher, staff member, guardian, or administrator known to the platform.",
        "required": [
          "id",
          "sourcedId",
          "displayName",
          "primaryRole",
          "enabledUser",
          "status",
          "dateLastModified"
        ],
        "properties": {
          "id": {
            "type": "string",
            "description": "The platform's stable ID for this person.",
            "x-decisionId": "DEC-007-identifier-crosswalk"
          },
          "sourcedId": {
            "type": "string",
            "description": "The OneRoster source ID used by the sending system.",
            "x-decisionId": "DEC-007-identifier-crosswalk"
          },
          "displayName": {
            "type": "string",
            "description": "The name shown in user interfaces.",
            "x-decisionId": "DEC-001-person-agent-subject"
          },
          "givenName": {
            "type": "string",
            "description": "The person's first or given name.",
            "x-decisionId": "DEC-001-person-agent-subject"
          },
          "familyName": {
            "type": "string",
            "description": "The person's last or family name.",
            "x-decisionId": "DEC-001-person-agent-subject"
          },
          "email": {
            "type": "string",
            "description": "The person's school email address.",
            "x-decisionId": "DEC-001-person-agent-subject"
          },
          "primaryRole": {
            "type": "string",
            "description": "The person's broad role in the education environment.",
            "x-decisionId": "DEC-003-role-vocabulary",
            "enum": [
              "student",
              "teacher",
              "administrator",
              "guardian"
            ]
          },
          "enabledUser": {
            "type": "string",
            "description": "Whether the person can currently sign in or be used as an active user.",
            "x-decisionId": "DEC-001-person-agent-subject",
            "enum": [
              "true",
              "false"
            ]
          },
          "status": {
            "type": "string",
            "description": "Whether the person record is active, inactive, or marked for deletion.",
            "x-decisionId": "DEC-001-person-agent-subject",
            "enum": [
              "active",
              "inactive",
              "tobedeleted"
